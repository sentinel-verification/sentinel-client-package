# ============================================================
# SENTINEL GATEWAY - CLIENT CONFIGURATION
# ============================================================

# 1. YOUR WALLET (Where your 60% business revenue gets sent)
SENTINEL_BUSINESS_WALLET=0x_CLIENTS_WALLET_ADDRESS_HERE

# 2. REFERRAL WALLET (The Agent/Hunter who referred you - Do not change)
SENTINEL_HUNTER_WALLET=0x_OPEN_CLAW_AGENT_WALLET_HERE

# 3. GLOBAL ROUTER (The Sentinel Protocol V2 Distribution Contract - Do not change)
SENTINEL_CONTRACT_ADDRESS=0xC8F8218Cc8F858BAdf3bc1a45b5d85E50666DbdF

# AGENT NETWORK REGISTRY (V2 Parent Agent Lookup - Do not change)
SENTINEL_AGENT_REGISTRY=0x188f810D1bcaa7Bc24cB4d56D3b2D300d78d8AdF

# 4. SECURITY & PRICING
SENTINEL_CACHE_PASSWORD=ChangeThisToARandomPassword123
SENTINEL_HMAC_SECRET=ChangeThisToARandomSecretKey123
SENTINEL_SETTLEMENT_AMOUNT=20000

# 5. REFERRAL REGISTRY CONTRACT v2 - Smart-Wallet Compatible (Do not change)
SENTINEL_REFERRAL_CONTRACT=0x3591f64D970B360231b62d035b1ff4a9C69897e0

# 6. BLOCKCHAIN RPC CONNECTION (Required for the Verifier to listen for payments)
SENTINEL_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
SENTINEL_RPC_WSS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# 7. SSL / HTTPS (Optional - leave empty for HTTP-only mode)
#    Set SENTINEL_DOMAIN to your public domain to enable automatic
#    Let's Encrypt TLS certificates and HTTP→HTTPS redirect.
#    When empty, the gateway runs on HTTP only (port 80) as before.
SENTINEL_DOMAIN=
SENTINEL_ACME_EMAIL=
